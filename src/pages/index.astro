---
// `?raw` returns the SVG file contents as a string and tells Vite NOT to emit
// it as a separate asset under dist/_astro/ — so the only place the SVG exists
// on the deployed site is inside index.html.
import logoSvg from '../assets/logo.svg?raw';
import { config } from '../config.js';
import { resolveColors } from '../lib/colors.js';

const {
  siteName,
  siteDescription,
  siteUrl,
  googleAnalyticsId,
  clarityProjectId,
  cloudflareAnalyticsToken,
  logoSize,
  fadeIn,
  fadeInDuration,
  hasOgImage,
  hasFavicon,
  enableStructuredData,
  organizationType,
} = config;

// Size presets: vw cap and vh cap. The browser picks the largest box that
// fits within both via `max-width: <vw>vw; max-height: <vh>vh; aspect-ratio: …`.
/** @type {Record<'normal' | 'large' | 'massive', { vw: number, vh: number }>} */
const logoSizes = {
  normal: { vw: 92, vh: 80 },
  large: { vw: 95, vh: 90 },
  massive: { vw: 98, vh: 95 },
};
const { vw: logoVw, vh: logoVh } =
  logoSize === 'large' || logoSize === 'massive' ? logoSizes[logoSize] : logoSizes.normal;

const structuredData = enableStructuredData
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': organizationType,
      name: siteName,
      url: siteUrl,
    })
  : null;

const { effectiveBg, css: colorCss } = resolveColors(config);

const cfBeaconData = cloudflareAnalyticsToken
  ? JSON.stringify({ token: cloudflareAnalyticsToken })
  : null;

// Parse the SVG's viewBox so the wrapper div can size itself to the *real*
// aspect ratio. We emit three CSS custom properties: the width/height numbers
// (unitless, for calc math) and a `W / H` string for the aspect-ratio property.
// Falls back to 1×1 if no viewBox is found.
const vbMatch = logoSvg.match(/viewBox\s*=\s*["']([\d.\s+-]+)["']/);
let logoAspectW = 1;
let logoAspectH = 1;
if (vbMatch) {
  const parts = vbMatch[1].trim().split(/\s+/);
  if (parts.length === 4 && Number(parts[2]) > 0 && Number(parts[3]) > 0) {
    logoAspectW = Number(parts[2]);
    logoAspectH = Number(parts[3]);
  }
}
const logoAspect = `${logoAspectW} / ${logoAspectH}`;

// Inject class + a11y attributes onto the inline <svg> root before it's set:html'd.
// Escaping the aria-label avoids breaking the attribute if siteName contains a quote.
const svgClass = ['logo', fadeIn ? 'animate' : null].filter(Boolean).join(' ');
const ariaLabel = siteName.replace(/"/g, '&quot;');
// Match the first <svg> tag (the file may start with an XML/HTML comment).
const logoMarkup = logoSvg.replace(
  /<svg\b/,
  `<svg class="${svgClass}" role="img" aria-label="${ariaLabel}"`,
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDescription} />
    <title>{siteName}</title>

    <!-- Favicon (only emitted when hasFavicon is true — there is no logo fallback) -->
    {hasFavicon && <link rel="icon" type="image/svg+xml" href="/favicon.svg" />}

    <!-- Preconnect for performance -->
    {googleAnalyticsId && <link rel="preconnect" href="https://www.googletagmanager.com" />}
    {clarityProjectId && <link rel="preconnect" href="https://www.clarity.ms" />}

    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content={effectiveBg} />

    <!-- Open Graph -->
    <meta property="og:title" content={siteName} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    {hasOgImage && <meta property="og:image" content={`${siteUrl}/og-image.png`} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={hasOgImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={siteName} />
    <meta name="twitter:description" content={siteDescription} />
    {hasOgImage && <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />}

    <!-- Structured Data -->
    {structuredData && <script type="application/ld+json" set:html={structuredData} />}

    <!-- Color scheme (set:html avoids define:vars inline specificity, allowing @media overrides) -->
    <style set:html={colorCss} />

    <style
      define:vars={{
        logoVw: `${logoVw}vw`,
        logoVh: `${logoVh}vh`,
        logoAspect,
        logoAspectW,
        logoAspectH,
        fadeInDuration: `${fadeInDuration}s`,
      }}
    >
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        height: 100%;
        width: 100%;
        overflow: hidden;
      }

      body {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .logo-container {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: clamp(0.5rem, 2vmin, 1.5rem);
      }

      /*
       * Inline <svg> as a flex child is famously inconsistent across browsers
       * (Chrome/Firefox treat it as 0×0 min, Edge/Safari use viewBox intrinsic
       * min), so we wrap it in a normal <div> that takes the responsive
       * sizing. The SVG fills the wrapper at 100%/100% — no flex-child
       * sizing quirks.
       *
       * Width is computed explicitly as `min(vw cap, vh cap × aspect)`:
       *   - var(--logoVw) is the vw cap (e.g. 92vw)
       *   - calc(var(--logoVh) * var(--logoAspectW) / var(--logoAspectH))
       *     is the width that would yield a height equal to the vh cap
       *   - min() takes whichever is smaller for the current viewport
       *
       * This guarantees the box never exceeds either viewport cap, regardless
       * of browser quirks with `aspect-ratio` + `max-height`. The aspect-ratio
       * property then derives the matching height from this width.
       */
      .logo-frame {
        width: min(
          var(--logoVw),
          calc(var(--logoVh) * var(--logoAspectW) / var(--logoAspectH))
        );
        aspect-ratio: var(--logoAspect);
        min-width: 0;
        min-height: 0;
        overflow: hidden;
      }

      .logo {
        display: block;
        width: 100%;
        height: 100%;
        /* Make it harder to grab the logo — friction, not protection. */
        user-select: none;
        -webkit-user-select: none;
        -webkit-user-drag: none;
        pointer-events: none;
      }

      .logo.animate {
        animation: fade-in var(--fadeInDuration) ease-out;
      }

      @keyframes fade-in {
        from {
          opacity: 0;
          transform: scale(0.96);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .logo.animate {
          animation: none;
        }
      }
    </style>

    <!-- Google Analytics 4 via Partytown -->
    {googleAnalyticsId && (
      <>
        <script
          type="text/partytown"
          src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}
        />
        <script type="text/partytown" define:vars={{ googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag('js', new Date());
          gtag('config', googleAnalyticsId, {
            anonymize_ip: true,
          });
        </script>
      </>
    )}

    <!-- Microsoft Clarity via Partytown -->
    {clarityProjectId && (
      <script type="text/partytown" define:vars={{ clarityProjectId }}>
        (function(c, l, a, r, i, t, y) {
          c[a] = c[a] || function() { (c[a].q = c[a].q || []).push(arguments); };
          t = l.createElement(r);
          t.async = 1;
          t.src = 'https://www.clarity.ms/tag/' + i;
          y = l.getElementsByTagName(r)[0];
          y.parentNode.insertBefore(t, y);
        })(window, document, 'clarity', 'script', clarityProjectId);
      </script>
    )}
  </head>

  <body>
    <main class="logo-container" draggable="false" oncontextmenu="return false">
      <div class="logo-frame">
        <Fragment set:html={logoMarkup} />
      </div>
    </main>

    <!-- Cloudflare Web Analytics -->
    {cfBeaconData && (
      <script
        defer
        src='https://static.cloudflareinsights.com/beacon.min.js'
        data-cf-beacon={cfBeaconData}
      />
    )}
  </body>
</html>
